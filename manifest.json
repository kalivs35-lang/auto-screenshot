{
  "manifest_version": 3,
  "name": "Auto Screenshot Tab",
  "version": "2.0",
  "description": "Automatically takes screenshots of a selected tab to a local directory.",
  "permissions": [
    "tabCapture",
    "desktopCapture",
    "tabs",
    "storage",
    "downloads"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  }
}
